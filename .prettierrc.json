{
  "printWidth": 120,
  "tabWidth": 4,
  "useTabs": false,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "semi": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "",
    "^react$",
    "^react/(.*)$",
    "",
    "^next$",
    "^next/(.*)$",
    "",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@widgets(/.*)?$",
    "^@features(/.*)?$",
    "^@entities(/.*)?$",
    "",
    "^@shared/i18n(/.*)?$",
    "^@shared/ui(/.*)?$",
    "^@shared/api(/.*)?$",
    "^@shared/lib(/.*)?$",
    "^@shared(/.*)?$",
    "",
    "^@/(.*)?$",
    "^src(/.*)?$",
    "",
    "^\\./(?=.*/)",
    "^\\./?$",
    "",
    "^\\.\\.(?:/|$)",
    "",
    "<TYPES>^@widgets(/.*)?$",
    "<TYPES>^@features(/.*)?$",
    "<TYPES>^@entities(/.*)?$",
    "<TYPES>^@shared/i18n(/.*)?$",
    "<TYPES>^@shared/ui(/.*)?$",
    "<TYPES>^@shared/api(/.*)?$",
    "<TYPES>^@shared/lib(/.*)?$",
    "<TYPES>^@shared(/.*)?$",
    "<TYPES>^@/(.*)?$",
    "<TYPES>^src(/.*)?$",
    "<TYPES>^\\./",
    "<TYPES>^\\.\\.(?:/|$)",
    "<TYPES>"
  ],
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "importOrderTypeScriptVersion": "5.0.0",
  "importOrderCaseSensitive": false,
  "overrides": [
    {
      "files": ["*.scss", "*.css", "*.json"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
